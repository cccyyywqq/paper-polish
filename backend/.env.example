# ============================================
# 开发环境配置
# ============================================
ENVIRONMENT=development
DEBUG=true

# AI服务配置 - 智谱GLM
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
ZHIPUAI_MODEL=glm-4-flash

# 认证安全配置
APP_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS 配置 (开发环境可选，留空使用默认值)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 数据库配置
DATABASE_URL=sqlite:///./paper_polish.db

# 应用配置
MAX_TEXT_LENGTH=10000
BATCH_SIZE=5
MAX_FILE_SIZE_MB=10

# LLM 配置
LLM_MAX_RETRIES=3
LLM_TIMEOUT=60
LLM_MAX_CONCURRENT=3

# ============================================
# 生产环境配置示例 (取消注释并修改)
# ============================================
# ENVIRONMENT=production
# DEBUG=false
# APP_SECRET_KEY=your-strong-random-secret-key-here
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
# DATABASE_URL=postgresql://user:password@localhost:5432/paper_polish
